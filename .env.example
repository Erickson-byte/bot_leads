# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# TELEGRAM_BOT_TOKEN: From BotFather
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"

# GOOGLE_SERVICE_ACCOUNT_EMAIL: Email of GCP Service account
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-acc@project-id.iam.gserviceaccount.com"

# GOOGLE_PRIVATE_KEY: Private key text (including BEGIN/END headers, replacing newlines with \n)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."

# GOOGLE_SHEET_ID: The ID from the Google Sheet URL
GOOGLE_SHEET_ID="your_google_sheet_id"

